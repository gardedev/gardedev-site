---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Thank You — GardeDev" description="We received your message and will be in touch within 24 hours.">
  <div class="min-h-screen bg-gray-50 flex flex-col items-center justify-center px-4 py-16">

    <!-- Logo -->
    <a href="/" class="mb-10 flex items-center">
      <img src="/logo-original.png" alt="GardeDev" class="h-10 w-auto" />
    </a>

    <!-- Card -->
    <div class="bg-white rounded-2xl shadow-lg border border-gray-100 max-w-lg w-full px-8 py-12 text-center">

      <!-- Icon -->
      <div class="w-16 h-16 rounded-full bg-[#002395]/10 flex items-center justify-center mx-auto mb-6">
        <svg width="32" height="32" fill="none" stroke="#002395" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
        </svg>
      </div>

      <h1 class="text-3xl font-black text-gray-950 mb-3">Message Received!</h1>
      <p class="text-gray-500 text-base leading-relaxed mb-2">
        Thanks for reaching out. We'll review your project details and get back to you within <strong class="text-gray-700">24 hours</strong>.
      </p>
      <p class="text-gray-400 text-sm mb-8">
        Questions? Email us at <a href="mailto:hello@gardedev.com" class="text-[#002395] hover:underline">hello@gardedev.com</a>
      </p>

      <a href="/" class="inline-flex items-center gap-2 bg-[#002395] hover:bg-[#001a7a] text-white font-bold text-sm px-6 py-3 rounded-lg transition">
        ← Back to Home
      </a>
    </div>

    <p class="mt-8 text-xs text-gray-400">&copy; 2025 GardeDev LLC. MBE Certified.</p>
  </div>
</Layout>
