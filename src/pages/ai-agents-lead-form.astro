---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
---

<Layout title="Get AI Agents for Your Business | GardeDev" description="Request a consultation for custom AI agents. Automate your business operations and save 20-40 hours per week.">
  <!-- NAV -->
  <header class="fixed top-0 left-0 right-0 z-50 bg-[#001a6e] shadow-lg">
    <nav class="max-w-7xl mx-auto px-4 sm:px-6 py-3 flex items-center justify-between">
      <a href="/" class="flex items-center shrink-0">
        <img src="/logo-original.png" alt="GardeDev" class="h-8 sm:h-10 w-auto" />
      </a>
      <div class="hidden md:flex items-center gap-8">
        <a href="/" class="nav-link-dark">Home</a>
        <a href="/#benefits" class="nav-link-dark">Benefits</a>
        <a href="/#services" class="nav-link-dark">Services</a>
      </div>
      <button id="menu-btn" class="md:hidden p-2 rounded-lg hover:bg-blue-800 shrink-0" aria-label="Menu">
        <svg width="24" height="24" fill="none" stroke="white" stroke-width="2"><path d="M4 6h16M4 12h16M4 18h16"/></svg>
      </button>
    </nav>
    <div id="mobile-menu" class="hidden md:hidden bg-[#001a6e] border-t border-blue-800 px-4 py-4 flex flex-col gap-3">
      <a href="/" class="nav-link-dark py-3 border-b border-blue-800 text-base font-medium">Home</a>
      <a href="/#benefits" class="nav-link-dark py-3 border-b border-blue-800 text-base font-medium">Benefits</a>
      <a href="/#services" class="nav-link-dark py-3 border-b border-blue-800 text-base font-medium">Services</a>
    </div>
  </header>

  <!-- HERO -->
  <section class="relative min-h-[40vh] flex items-center pt-20 overflow-hidden">
    <div class="absolute inset-0 z-0">
      <img src="/ai-lead-form-hero.png" alt="" class="w-full h-full object-cover opacity-40" />
      <div class="absolute inset-0 bg-gradient-to-br from-[#001a6e]/95 via-[#001a6e]/85 to-[#002395]/80"></div>
    </div>
    
    <div class="relative z-20 w-full max-w-7xl mx-auto px-4 sm:px-6 py-12 sm:py-16">
      <div class="text-center max-w-3xl mx-auto">
        <div class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm text-white text-sm font-semibold px-4 py-2 rounded-full mb-4 border border-white/20">
          <svg width="14" height="14" fill="#ED2939" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
          Free Consultation
        </div>
        <h1 class="text-3xl sm:text-4xl lg:text-5xl font-black leading-[1.1] mb-4 text-white">
          Get Your Custom<br/>
          <span class="text-[#ED2939]">AI Agents</span>
        </h1>
        <p class="text-lg text-blue-100 leading-relaxed">
          Partner with experienced AI architects who prioritize your security and ROI.
        </p>
      </div>
    </div>
  </section>

  <!-- TWO COLUMN SECTION -->
  <section class="py-16 sm:py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16">
        
        <!-- LEFT COLUMN: Selling Points -->
        <div class="order-2 lg:order-1">
          <h2 class="text-2xl sm:text-3xl font-black text-gray-950 mb-6">Why Choose GardeDev?</h2>
          <p class="text-gray-600 mb-8">We don't just build AI agents — we architect intelligent solutions that deliver measurable business results while keeping your data secure.</p>
          
          <div class="space-y-6">
            <!-- Point 1 -->
            <div class="flex gap-4">
              <div class="w-12 h-12 bg-[#002395]/10 rounded-xl flex items-center justify-center shrink-0">
                <svg width="24" height="24" fill="none" stroke="#002395" stroke-width="2" viewBox="0 0 24 24"><path d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              </div>
              <div>
                <h3 class="text-lg font-bold text-gray-900 mb-1">20 Years of Experience</h3>
                <p class="text-gray-600 text-sm leading-relaxed">Two decades of building enterprise software means we understand what actually works in production. We've seen the pitfalls and know how to avoid them.</p>
              </div>
            </div>

            <!-- Point 2 -->
            <div class="flex gap-4">
              <div class="w-12 h-12 bg-[#ED2939]/10 rounded-xl flex items-center justify-center shrink-0">
                <svg width="24" height="24" fill="none" stroke="#ED2939" stroke-width="2" viewBox="0 0 24 24"><path d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 002 2h2a2 2 0 002-2z"/></svg>
              </div>
              <div>
                <h3 class="text-lg font-bold text-gray-900 mb-1">Optimized Model Selection</h3>
                <p class="text-gray-600 text-sm leading-relaxed">We match the right AI models to your specific use case — balancing capability, speed, and cost. No over-engineering, no wasted spend.</p>
              </div>
            </div>

            <!-- Point 3 -->
            <div class="flex gap-4">
              <div class="w-12 h-12 bg-[#002395]/10 rounded-xl flex items-center justify-center shrink-0">
                <svg width="24" height="24" fill="none" stroke="#002395" stroke-width="2" viewBox="0 0 24 24"><path d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
              </div>
              <div>
                <h3 class="text-lg font-bold text-gray-900 mb-1">Security-First Architecture</h3>
                <p class="text-gray-600 text-sm leading-relaxed">We prioritize data protection with limited sensitive access, secure API handling, and compliance-conscious design. Your data stays yours.</p>
              </div>
            </div>

            <!-- Point 4 -->
            <div class="flex gap-4">
              <div class="w-12 h-12 bg-[#ED2939]/10 rounded-xl flex items-center justify-center shrink-0">
                <svg width="24" height="24" fill="none" stroke="#ED2939" stroke-width="2" viewBox="0 0 24 24"><path d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>
              </div>
              <div>
                <h3 class="text-lg font-bold text-gray-900 mb-1">Structured Skills & Agent Layout</h3>
                <p class="text-gray-600 text-sm leading-relaxed">We design agent hierarchies and skill architectures tailored to your company's workflows — not generic templates, but purpose-built systems.</p>
              </div>
            </div>

            <!-- Point 5 -->
            <div class="flex gap-4">
              <div class="w-12 h-12 bg-[#002395]/10 rounded-xl flex items-center justify-center shrink-0">
                <svg width="24" height="24" fill="none" stroke="#002395" stroke-width="2" viewBox="0 0 24 24"><path d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
              </div>
              <div>
                <h3 class="text-lg font-bold text-gray-900 mb-1">Measurable ROI</h3>
                <p class="text-gray-600 text-sm leading-relaxed">We track the metrics that matter — time saved, costs reduced, customer satisfaction improved. You'll see clear results within weeks, not months.</p>
              </div>
            </div>
          </div>

          <!-- Trust Badge -->
          <div class="mt-8 p-4 bg-gray-50 rounded-xl border border-gray-100">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 bg-[#002395] rounded-lg flex items-center justify-center">
                <svg width="20" height="20" fill="white" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
              </div>
              <div>
                <p class="font-semibold text-gray-900 text-sm">MBE Certified</p>
                <p class="text-xs text-gray-500">Minority Business Enterprise</p>
              </div>
            </div>
          </div>
        </div>

        <!-- RIGHT COLUMN: Form -->
        <div class="order-1 lg:order-2">
          <div class="bg-gray-50 rounded-2xl p-6 sm:p-8 border border-gray-100 shadow-lg sticky top-24">
            <h3 class="text-xl font-bold text-gray-900 mb-2">Request Your Consultation</h3>
            <p class="text-gray-500 text-sm mb-6">Tell us about your needs and we'll design a custom AI solution.</p>
            
            <form id="leadForm" class="space-y-4">
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div>
                  <label class="block text-sm font-semibold text-gray-700 mb-1.5" for="name">Full Name *</label>
                  <input id="name" name="name" type="text" required placeholder="John Smith" class="w-full px-3 py-2.5 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-[#002395] focus:border-transparent transition text-gray-900 placeholder-gray-400 text-sm" />
                </div>
                <div>
                  <label class="block text-sm font-semibold text-gray-700 mb-1.5" for="email">Email *</label>
                  <input id="email" name="email" type="email" required placeholder="john@company.com" class="w-full px-3 py-2.5 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-[#002395] focus:border-transparent transition text-gray-900 placeholder-gray-400 text-sm" />
                </div>
              </div>
              
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div>
                  <label class="block text-sm font-semibold text-gray-700 mb-1.5" for="company">Company *</label>
                  <input id="company" name="company" type="text" required placeholder="Your Company" class="w-full px-3 py-2.5 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-[#002395] focus:border-transparent transition text-gray-900 placeholder-gray-400 text-sm" />
                </div>
                <div>
                  <label class="block text-sm font-semibold text-gray-700 mb-1.5" for="phone">Phone</label>
                  <input id="phone" name="phone" type="tel" placeholder="(555) 123-4567" class="w-full px-3 py-2.5 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-[#002395] focus:border-transparent transition text-gray-900 placeholder-gray-400 text-sm" />
                </div>
              </div>

              <div>
                <label class="block text-sm font-semibold text-gray-700 mb-1.5" for="hours">Hours/week on repetitive tasks *</label>
                <select id="hours" name="hours" required class="w-full px-3 py-2.5 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-[#002395] focus:border-transparent transition text-gray-900 text-sm bg-white">
                  <option value="">Select an option</option>
                  <option value="0-10">0-10 hours</option>
                  <option value="10-20">10-20 hours</option>
                  <option value="20-40">20-40 hours</option>
                  <option value="40+">40+ hours</option>
                </select>
              </div>

              <div>
                <label class="block text-sm font-semibold text-gray-700 mb-1.5" for="tasks">What tasks would you like to automate? *</label>
                <textarea id="tasks" name="tasks" required rows="3" placeholder="Describe the repetitive tasks your team handles..." class="w-full px-3 py-2.5 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-[#002395] focus:border-transparent transition text-gray-900 placeholder-gray-400 resize-none text-sm"></textarea>
              </div>

              <div class="h-captcha" data-sitekey="e102b9ae-b390-432e-9498-906c007c0294" data-size="compact"></div>
              
              <button type="submit" id="submitBtn" class="btn-primary w-full justify-center text-sm py-3 bg-[#ED2939] hover:bg-[#c41e2b]">
                Request Consultation
                <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </button>
              
              <p class="text-xs text-gray-400 text-center">
                Free consultation. No obligation. We respect your privacy.
              </p>
            </form>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="bg-[#002395] text-white py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="flex flex-col md:flex-row items-center justify-between gap-6">
        <div class="flex items-center">
          <img src="/logo-original.png" alt="GardeDev" class="h-10 w-auto" />
        </div>
        <div class="flex flex-wrap justify-center gap-6 text-sm text-blue-200">
          <a href="/" class="hover:text-white transition">Home</a>
          <a href="/#benefits" class="hover:text-white transition">Benefits</a>
          <a href="/#services" class="hover:text-white transition">Services</a>
        </div>
        <p class="text-sm text-blue-200 text-center">&copy; 2025 GardeDev LLC. MBE Certified.</p>
      </div>
    </div>
  </footer>

  <script src="https://js.hcaptcha.com/1/api.js" async defer></script>
  <script>
    // Mobile menu toggle
    const btn = document.getElementById('menu-btn');
    const menu = document.getElementById('mobile-menu');
    btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));

    // Form submission
    const leadForm = document.getElementById('leadForm');
    leadForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const token = (window as any).hcaptcha?.getResponse();
      if (!token) {
        alert('Please complete the CAPTCHA to continue.');
        return;
      }
      const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement;
      submitBtn.textContent = 'Sending…';
      submitBtn.disabled = true;
      try {
        const formData = new FormData(leadForm as HTMLFormElement);
        formData.delete('h-captcha-response');
        formData.append('h-captcha-response', token);
        const res = await fetch('https://formspree.io/f/xwpqodpy', {
          method: 'POST',
          body: formData,
          headers: { 'Accept': 'application/json' }
        });
        const json = await res.json();
        if (res.ok) {
          window.location.href = '/thank-you?source=ai-agents';
        } else {
          submitBtn.textContent = 'Request Consultation';
          submitBtn.disabled = false;
          (window as any).hcaptcha?.reset();
          alert((json.errors && json.errors.map((err: any) => err.message).join(', ')) || 'Something went wrong. Please try again.');
        }
      } catch {
        submitBtn.textContent = 'Request Consultation';
        submitBtn.disabled = false;
        (window as any).hcaptcha?.reset();
        alert('Network error. Please try again.');
      }
    });
  </script>
</Layout>