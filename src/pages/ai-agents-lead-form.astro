---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
---

<Layout title="Get AI Agents for Your Business | GardeDev" description="Request a consultation for custom AI agents. Automate your business operations and save 20-40 hours per week.">
  <!-- NAV -->
  <header class="fixed top-0 left-0 right-0 z-50 bg-[#001a6e] shadow-lg">
    <nav class="max-w-7xl mx-auto px-4 sm:px-6 py-3 flex items-center justify-between">
      <a href="/" class="flex items-center shrink-0">
        <img src="/logo-original.png" alt="GardeDev" class="h-8 sm:h-10 w-auto" />
      </a>
      <div class="hidden md:flex items-center gap-8">
        <a href="/" class="nav-link-dark">Home</a>
        <a href="/#benefits" class="nav-link-dark">Benefits</a>
        <a href="/#services" class="nav-link-dark">Services</a>
      </div>
      <button id="menu-btn" class="md:hidden p-2 rounded-lg hover:bg-blue-800 shrink-0" aria-label="Menu">
        <svg width="24" height="24" fill="none" stroke="white" stroke-width="2"><path d="M4 6h16M4 12h16M4 18h16"/></svg>
      </button>
    </nav>
    <div id="mobile-menu" class="hidden md:hidden bg-[#001a6e] border-t border-blue-800 px-4 py-4 flex flex-col gap-3">
      <a href="/" class="nav-link-dark py-3 border-b border-blue-800 text-base font-medium">Home</a>
      <a href="/#benefits" class="nav-link-dark py-3 border-b border-blue-800 text-base font-medium">Benefits</a>
      <a href="/#services" class="nav-link-dark py-3 border-b border-blue-800 text-base font-medium">Services</a>
    </div>
  </header>

  <!-- HERO -->
  <section class="relative min-h-[50vh] flex items-center pt-20 overflow-hidden">
    <div class="absolute inset-0 z-0">
      <img src="/ai-lead-form-hero.png" alt="" class="w-full h-full object-cover opacity-40" />
      <div class="absolute inset-0 bg-gradient-to-br from-[#001a6e]/95 via-[#001a6e]/85 to-[#002395]/80"></div>
    </div>
    
    <div class="relative z-20 w-full max-w-7xl mx-auto px-4 sm:px-6 py-16 sm:py-24">
      <div class="text-center max-w-3xl mx-auto">
        <div class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm text-white text-sm font-semibold px-4 py-2 rounded-full mb-6 border border-white/20">
          <svg width="14" height="14" fill="#ED2939" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
          Free Consultation
        </div>
        <h1 class="text-3xl sm:text-4xl lg:text-5xl font-black leading-[1.1] mb-6 text-white">
          Get Your Custom<br/>
          <span class="text-[#ED2939]">AI Agents</span>
        </h1>
        <p class="text-lg text-blue-100 leading-relaxed">
          Tell us about your business and the tasks you want to automate. We'll design a custom AI solution that saves you time and money.
        </p>
      </div>
    </div>
  </section>

  <!-- FORM SECTION -->
  <section class="py-16 sm:py-24 bg-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      <div class="bg-gray-50 rounded-2xl p-8 sm:p-12 border border-gray-100 shadow-lg">
        <form id="leadForm" class="space-y-6">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-2" for="name">Full Name *</label>
              <input id="name" name="name" type="text" required placeholder="John Smith" class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-[#002395] focus:border-transparent transition text-gray-900 placeholder-gray-400 text-base" />
            </div>
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-2" for="email">Email Address *</label>
              <input id="email" name="email" type="email" required placeholder="john@company.com" class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-[#002395] focus:border-transparent transition text-gray-900 placeholder-gray-400 text-base" />
            </div>
          </div>
          
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-2" for="company">Company Name *</label>
              <input id="company" name="company" type="text" required placeholder="Your Company" class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-[#002395] focus:border-transparent transition text-gray-900 placeholder-gray-400 text-base" />
            </div>
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-2" for="phone">Phone Number</label>
              <input id="phone" name="phone" type="tel" placeholder="(555) 123-4567" class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-[#002395] focus:border-transparent transition text-gray-900 placeholder-gray-400 text-base" />
            </div>
          </div>

          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-2" for="hours">Hours per week on repetitive tasks *</label>
            <select id="hours" name="hours" required class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-[#002395] focus:border-transparent transition text-gray-900 text-base bg-white">
              <option value="">Select an option</option>
              <option value="0-10">0-10 hours</option>
              <option value="10-20">10-20 hours</option>
              <option value="20-40">20-40 hours</option>
              <option value="40+">40+ hours</option>
            </select>
          </div>

          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-2" for="tasks">What tasks would you like to automate? *</label>
            <textarea id="tasks" name="tasks" required rows="4" placeholder="Describe the repetitive tasks your team handles: customer inquiries, data entry, scheduling, follow-ups, reporting, etc." class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-[#002395] focus:border-transparent transition text-gray-900 placeholder-gray-400 resize-none text-base"></textarea>
          </div>

          <div class="h-captcha" data-sitekey="e102b9ae-b390-432e-9498-906c007c0294"></div>
          
          <button type="submit" id="submitBtn" class="btn-primary w-full justify-center text-base py-4 bg-[#ED2939] hover:bg-[#c41e2b]">
            Request AI Agent Consultation
            <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </button>
          
          <p class="text-xs text-gray-500 text-center">
            By submitting this form, you agree to our privacy policy. We'll never share your information.
          </p>
        </form>
      </div>

      <!-- Trust Indicators -->
      <div class="mt-12 grid grid-cols-1 sm:grid-cols-3 gap-6 text-center">
        <div class="flex flex-col items-center">
          <div class="w-12 h-12 bg-blue-50 rounded-xl flex items-center justify-center mb-3">
            <svg width="24" height="24" fill="none" stroke="#002395" stroke-width="2" viewBox="0 0 24 24"><path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
          </div>
          <h4 class="font-semibold text-gray-900 text-sm">MBE Certified</h4>
          <p class="text-xs text-gray-500 mt-1">Minority Business Enterprise</p>
        </div>
        <div class="flex flex-col items-center">
          <div class="w-12 h-12 bg-red-50 rounded-xl flex items-center justify-center mb-3">
            <svg width="24" height="24" fill="none" stroke="#ED2939" stroke-width="2" viewBox="0 0 24 24"><path d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <h4 class="font-semibold text-gray-900 text-sm">Fast Response</h4>
          <p class="text-xs text-gray-500 mt-1">Within 24 hours</p>
        </div>
        <div class="flex flex-col items-center">
          <div class="w-12 h-12 bg-blue-50 rounded-xl flex items-center justify-center mb-3">
            <svg width="24" height="24" fill="none" stroke="#002395" stroke-width="2" viewBox="0 0 24 24"><path d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
          </div>
          <h4 class="font-semibold text-gray-900 text-sm">No Obligation</h4>
          <p class="text-xs text-gray-500 mt-1">Free consultation</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="bg-[#002395] text-white py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="flex flex-col md:flex-row items-center justify-between gap-6">
        <div class="flex items-center">
          <img src="/logo-original.png" alt="GardeDev" class="h-10 w-auto" />
        </div>
        <div class="flex flex-wrap justify-center gap-6 text-sm text-blue-200">
          <a href="/" class="hover:text-white transition">Home</a>
          <a href="/#benefits" class="hover:text-white transition">Benefits</a>
          <a href="/#services" class="hover:text-white transition">Services</a>
        </div>
        <p class="text-sm text-blue-200 text-center">&copy; 2025 GardeDev LLC. MBE Certified.</p>
      </div>
    </div>
  </footer>

  <script src="https://js.hcaptcha.com/1/api.js" async defer></script>
  <script>
    // Mobile menu toggle
    const btn = document.getElementById('menu-btn');
    const menu = document.getElementById('mobile-menu');
    btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));

    // Form submission
    const leadForm = document.getElementById('leadForm');
    leadForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const token = (window as any).hcaptcha?.getResponse();
      if (!token) {
        alert('Please complete the CAPTCHA to continue.');
        return;
      }
      const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement;
      submitBtn.textContent = 'Sending…';
      submitBtn.disabled = true;
      try {
        const formData = new FormData(leadForm as HTMLFormElement);
        formData.delete('h-captcha-response');
        formData.append('h-captcha-response', token);
        const res = await fetch('https://formspree.io/f/xwpqodpy', {
          method: 'POST',
          body: formData,
          headers: { 'Accept': 'application/json' }
        });
        const json = await res.json();
        if (res.ok) {
          window.location.href = '/thank-you?source=ai-agents';
        } else {
          submitBtn.textContent = 'Request AI Agent Consultation';
          submitBtn.disabled = false;
          (window as any).hcaptcha?.reset();
          alert((json.errors && json.errors.map((err: any) => err.message).join(', ')) || 'Something went wrong. Please try again.');
        }
      } catch {
        submitBtn.textContent = 'Request AI Agent Consultation';
        submitBtn.disabled = false;
        (window as any).hcaptcha?.reset();
        alert('Network error. Please try again.');
      }
    });
  </script>
</Layout>