---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
---

<Layout title="GardeDev – AI Agents for Your Business | MBE Certified" description="Transform your business with custom AI Agents. Automate customer service, workflows, and repetitive tasks. Save 20-40 hours per week. MBE Certified.">
  <!-- NAV -->
  <header class="fixed top-0 left-0 right-0 z-50 bg-[#001a6e] shadow-lg">
    <nav class="max-w-7xl mx-auto px-4 sm:px-6 py-3 flex items-center justify-between">
      <a href="/" class="flex items-center shrink-0">
        <img src="/logo-original.png" alt="GardeDev" class="h-8 sm:h-10 w-auto" />
      </a>
      <div class="hidden md:flex items-center gap-8">
        <a href="/ai-agents-lead-form" class="btn-primary text-sm py-2 px-5">Get AI Agents</a>
      </div>
      <button id="menu-btn" class="md:hidden p-2 rounded-lg hover:bg-blue-800 shrink-0" aria-label="Menu">
        <svg width="24" height="24" fill="none" stroke="white" stroke-width="2"><path d="M4 6h16M4 12h16M4 18h16"/></svg>
      </button>
    </nav>
    <div id="mobile-menu" class="hidden md:hidden bg-[#001a6e] border-t border-blue-800 px-4 py-4 flex flex-col gap-3">
      <a href="/ai-agents-lead-form" class="btn-primary text-center justify-center mt-2">Get AI Agents</a>
    </div>
  </header>

  <!-- AI AGENTS HERO -->
  <section id="ai-agents" class="relative min-h-screen flex items-center pt-16 sm:pt-20 overflow-hidden">
    <!-- Background Image -->
    <div class="absolute inset-0 z-0">
      <img src="/ai-agents-hero-bg.png" alt="" class="w-full h-full object-cover opacity-30" />
      <div class="absolute inset-0 bg-gradient-to-br from-[#001a6e]/90 via-[#001a6e]/80 to-[#002395]/70"></div>
    </div>
    
    <div class="relative z-20 w-full max-w-7xl mx-auto px-4 sm:px-6 py-12 sm:py-20 lg:py-28">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <!-- Mobile Hero Image -->
          <div class="lg:hidden mb-6">
            <img src="/ai-customer-service.png" alt="AI Customer Service" class="rounded-2xl shadow-2xl border border-white/20 w-full max-w-md mx-auto" />
          </div>
          
          <div class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm text-white text-sm font-semibold px-4 py-2 rounded-full mb-6 border border-white/20">
            <svg width="14" height="14" fill="#ED2939" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
            MBE Certified Company
          </div>
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-black leading-[1.1] mb-6 text-white">
            Create AI Agents<br/>
            <span class="text-[#ED2939]">For Your</span><br/>
            <span class="relative inline-block">Company<span class="absolute -bottom-1 left-0 right-0 h-1.5 bg-[#ED2939] rounded"></span></span>
          </h1>
          <p class="text-lg sm:text-xl text-blue-100 mb-10 leading-relaxed max-w-xl">
            Transform your business operations with intelligent AI agents that work 24/7. Automate customer service, streamline workflows, and reclaim 20-40 hours every week.
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <a href="/ai-agents-lead-form" class="btn-primary justify-center sm:justify-start bg-[#ED2939] hover:bg-[#c41e2b]">
              Get Your AI Agents
              <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
            <a href="#benefits" class="inline-flex items-center justify-center sm:justify-start gap-2 px-6 py-3 border-2 border-white/30 text-white font-semibold rounded-lg hover:bg-white/10 transition">
              See How It Works
            </a>
          </div>
        </div>
        <div class="hidden lg:block">
          <div class="relative">
            <img src="/ai-customer-service.png" alt="AI Customer Service" class="rounded-2xl shadow-2xl border border-white/20" />
            <div class="absolute -bottom-6 -left-6 bg-white rounded-xl shadow-xl p-4 border border-gray-100">
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 bg-green-100 rounded-full flex items-center justify-center">
                  <svg width="20" height="20" fill="none" stroke="#10b981" stroke-width="2" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"/></svg>
                </div>
                <div>
                  <p class="text-sm font-semibold text-gray-900">Response Time</p>
                  <p class="text-xs text-gray-500">Under 5 seconds</p>
                </div>
              </div>
            </div>
            <div class="absolute -top-6 -right-6 bg-[#ED2939] rounded-xl shadow-xl p-4 text-white">
              <p class="text-2xl font-black">40+</p>
              <p class="text-xs opacity-90">Hours Saved/Week</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- AI STATS -->
  <section class="py-14 bg-[#ED2939]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        <div class="text-center">
          <div class="text-4xl sm:text-5xl font-black text-white mb-1">24/7</div>
          <div class="text-red-100 text-sm font-medium">Always Available</div>
        </div>
        <div class="text-center">
          <div class="text-4xl sm:text-5xl font-black text-white mb-1">80<span class="text-[#002395]">%</span></div>
          <div class="text-red-100 text-sm font-medium">Faster Response</div>
        </div>
        <div class="text-center">
          <div class="text-4xl sm:text-5xl font-black text-white mb-1">20-40</div>
          <div class="text-red-100 text-sm font-medium">Hours Saved Weekly</div>
        </div>
        <div class="text-center">
          <div class="text-4xl sm:text-5xl font-black text-white mb-1">3<span class="text-[#002395]">x</span></div>
          <div class="text-red-100 text-sm font-medium">More Productive</div>
        </div>
      </div>
    </div>
  </section>

  <!-- BENEFITS SECTION -->
  <section id="benefits" class="py-20 sm:py-28 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-14">
        <p class="text-sm font-semibold text-[#ED2939] uppercase tracking-widest mb-3">What AI Agents Do For You</p>
        <h2 class="text-3xl sm:text-4xl font-black text-gray-950 mb-4">Reclaim Your Time. Scale Your Business.</h2>
        <p class="text-base sm:text-lg text-gray-500 max-w-2xl mx-auto">Our AI agents handle the repetitive work so your team can focus on what matters most.</p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="bg-gray-50 rounded-2xl p-8 border border-gray-100 hover:shadow-lg transition">
          <div class="w-14 h-14 bg-[#002395]/10 rounded-xl flex items-center justify-center mb-5">
            <svg width="28" height="28" fill="none" stroke="#002395" stroke-width="2" viewBox="0 0 24 24"><path d="M17 8h2a2 2 0 012 2v6a2 2 0 01-2 2h-2v4l-4-4H9a1.994 1.994 0 01-1.414-.586m0 0L11 14h4a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2v4l.586-.586z"/></svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">24/7 Customer Support</h3>
          <p class="text-gray-600 leading-relaxed mb-4">AI agents handle customer inquiries around the clock. No more missed messages, no more after-hours emergencies.</p>
          <div class="flex items-center gap-2 text-sm text-[#002395] font-semibold">
            <span>Saves 15+ hours/week</span>
          </div>
        </div>

        <div class="bg-gray-50 rounded-2xl p-8 border border-gray-100 hover:shadow-lg transition">
          <div class="w-14 h-14 bg-[#ED2939]/10 rounded-xl flex items-center justify-center mb-5">
            <svg width="28" height="28" fill="none" stroke="#ED2939" stroke-width="2" viewBox="0 0 24 24"><path d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">Instant Response Times</h3>
          <p class="text-gray-600 leading-relaxed mb-4">Reduce response times from hours to seconds. Your customers get immediate answers, improving satisfaction.</p>
          <div class="flex items-center gap-2 text-sm text-[#ED2939] font-semibold">
            <span>Under 5 second response</span>
          </div>
        </div>

        <div class="bg-gray-50 rounded-2xl p-8 border border-gray-100 hover:shadow-lg transition">
          <div class="w-14 h-14 bg-[#002395]/10 rounded-xl flex items-center justify-center mb-5">
            <svg width="28" height="28" fill="none" stroke="#002395" stroke-width="2" viewBox="0 0 24 24"><path d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">Workflow Automation</h3>
          <p class="text-gray-600 leading-relaxed mb-4">Automate repetitive tasks like data entry, scheduling, follow-ups, and report generation.</p>
          <div class="flex items-center gap-2 text-sm text-[#002395] font-semibold">
            <span>Automates 10+ workflows</span>
          </div>
        </div>

        <div class="bg-gray-50 rounded-2xl p-8 border border-gray-100 hover:shadow-lg transition">
          <div class="w-14 h-14 bg-[#ED2939]/10 rounded-xl flex items-center justify-center mb-5">
            <svg width="28" height="28" fill="none" stroke="#ED2939" stroke-width="2" viewBox="0 0 24 24"><path d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 002 2h2a2 2 0 002-2z"/></svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">Scale Without Hiring</h3>
          <p class="text-gray-600 leading-relaxed mb-4">Handle 10x the volume without adding headcount. AI agents scale instantly to meet demand.</p>
          <div class="flex items-center gap-2 text-sm text-[#ED2939] font-semibold">
            <span>Unlimited scalability</span>
          </div>
        </div>

        <div class="bg-gray-50 rounded-2xl p-8 border border-gray-100 hover:shadow-lg transition">
          <div class="w-14 h-14 bg-[#002395]/10 rounded-xl flex items-center justify-center mb-5">
            <svg width="28" height="28" fill="none" stroke="#002395" stroke-width="2" viewBox="0 0 24 24"><path d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">Consistent Quality</h3>
          <p class="text-gray-600 leading-relaxed mb-4">Every interaction follows your brand guidelines. No bad days, no inconsistent messaging.</p>
          <div class="flex items-center gap-2 text-sm text-[#002395] font-semibold">
            <span>100% brand consistency</span>
          </div>
        </div>

        <div class="bg-gray-50 rounded-2xl p-8 border border-gray-100 hover:shadow-lg transition">
          <div class="w-14 h-14 bg-[#ED2939]/10 rounded-xl flex items-center justify-center mb-5">
            <svg width="28" height="28" fill="none" stroke="#ED2939" stroke-width="2" viewBox="0 0 24 24"><path d="M11 4a2 2 0 114 0v1a1 1 0 001 1h3a1 1 0 011 1v3a1 1 0 01-1 1h-1a2 2 0 100 4h1a1 1 0 011 1v3a1 1 0 01-1 1h-3a1 1 0 01-1-1v-1a2 2 0 10-4 0v1a1 1 0 01-1 1H7a1 1 0 01-1-1v-3a1 1 0 00-1-1H4a2 2 0 110-4h1a1 1 0 001-1V7a1 1 0 011-1h3a1 1 0 001-1V4z"/></svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">Seamless Integration</h3>
          <p class="text-gray-600 leading-relaxed mb-4">Connects with your existing tools — email, CRM, Slack, calendars, and more.</p>
          <div class="flex items-center gap-2 text-sm text-[#ED2939] font-semibold">
            <span>50+ integrations</span>
          </div>
        </div>
      </div>

      <div class="mt-12 text-center">
        <a href="/ai-agents-lead-form" class="btn-primary inline-flex">
          Get Started with AI Agents
          <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- WHY GARDEDEV -->
  <section class="py-20 sm:py-28 bg-[#001a6e] dot-grid">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <div>
          <p class="text-sm font-semibold text-[#ED2939] uppercase tracking-widest mb-3">Why Partner With Us</p>
          <h2 class="text-3xl sm:text-4xl font-black text-white mb-6">Experience That Delivers Results</h2>
          <p class="text-blue-200 leading-relaxed mb-8">We don't just build AI agents — we architect intelligent solutions that prioritize your security, optimize your spend, and deliver measurable ROI.</p>
          
          <div class="space-y-5">
            <div class="flex gap-4">
              <div class="w-10 h-10 bg-[#ED2939]/20 rounded-lg flex items-center justify-center shrink-0">
                <svg width="20" height="20" fill="none" stroke="#ED2939" stroke-width="2" viewBox="0 0 24 24"><path d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              </div>
              <div>
                <h3 class="text-white font-bold mb-1">20 Years of Experience</h3>
                <p class="text-blue-200 text-sm">Two decades building enterprise software. We've seen the pitfalls and know how to avoid them.</p>
              </div>
            </div>
            
            <div class="flex gap-4">
              <div class="w-10 h-10 bg-[#ED2939]/20 rounded-lg flex items-center justify-center shrink-0">
                <svg width="20" height="20" fill="none" stroke="#ED2939" stroke-width="2" viewBox="0 0 24 24"><path d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 002 2h2a2 2 0 002-2z"/></svg>
              </div>
              <div>
                <h3 class="text-white font-bold mb-1">Optimized Model Selection</h3>
                <p class="text-blue-200 text-sm">Right-size AI models for your use case — balancing capability, speed, and cost. No wasted spend.</p>
              </div>
            </div>
            
            <div class="flex gap-4">
              <div class="w-10 h-10 bg-[#ED2939]/20 rounded-lg flex items-center justify-center shrink-0">
                <svg width="20" height="20" fill="none" stroke="#ED2939" stroke-width="2" viewBox="0 0 24 24"><path d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
              </div>
              <div>
                <h3 class="text-white font-bold mb-1">Security-First Architecture</h3>
                <p class="text-blue-200 text-sm">Limited sensitive access, secure API handling, compliance-conscious design. Your data stays yours.</p>
              </div>
            </div>
            
            <div class="flex gap-4">
              <div class="w-10 h-10 bg-[#ED2939]/20 rounded-lg flex items-center justify-center shrink-0">
                <svg width="20" height="20" fill="none" stroke="#ED2939" stroke-width="2" viewBox="0 0 24 24"><path d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>
              </div>
              <div>
                <h3 class="text-white font-bold mb-1">Structured Agent Layout</h3>
                <p class="text-blue-200 text-sm">Purpose-built agent hierarchies and skill architectures tailored to your workflows — not generic templates.</p>
              </div>
            </div>
          </div>
          
          <div class="mt-8">
            <a href="/ai-agents-lead-form" class="btn-primary inline-flex bg-[#ED2939] hover:bg-[#c41e2b]">
              Schedule a Consultation
              <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>
        </div>
        
        <div class="hidden lg:block">
          <div class="relative">
            <img src="/ai-automation.png" alt="AI Automation" class="rounded-2xl shadow-2xl border border-white/10" />
            <div class="absolute -bottom-6 -right-6 bg-[#ED2939] rounded-xl shadow-xl p-4 text-white">
              <p class="text-3xl font-black">20+</p>
              <p class="text-xs opacity-90">Years Experience</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section class="py-20 sm:py-28 bg-gray-50 dot-grid">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-14">
        <p class="text-sm font-semibold text-[#ED2939] uppercase tracking-widest mb-3">Simple Process</p>
        <h2 class="text-3xl sm:text-4xl font-black text-gray-950 mb-4">Get Your AI Agent in 3 Steps</h2>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100 text-center relative">
          <div class="absolute -top-4 left-1/2 -translate-x-1/2 w-8 h-8 bg-[#002395] text-white rounded-full flex items-center justify-center font-bold">1</div>
          <h3 class="text-lg font-bold text-gray-900 mb-2 mt-4">Tell Us Your Needs</h3>
          <p class="text-gray-500 text-sm">Share what tasks you want automated and how your business operates.</p>
        </div>
        
        <div class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100 text-center relative">
          <div class="absolute -top-4 left-1/2 -translate-x-1/2 w-8 h-8 bg-[#ED2939] text-white rounded-full flex items-center justify-center font-bold">2</div>
          <h3 class="text-lg font-bold text-gray-900 mb-2 mt-4">We Build Your Agent</h3>
          <p class="text-gray-500 text-sm">Our team customizes and trains your AI agent for your specific use case.</p>
        </div>
        
        <div class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100 text-center relative">
          <div class="absolute -top-4 left-1/2 -translate-x-1/2 w-8 h-8 bg-[#002395] text-white rounded-full flex items-center justify-center font-bold">3</div>
          <h3 class="text-lg font-bold text-gray-900 mb-2 mt-4">Go Live & Save Time</h3>
          <p class="text-gray-500 text-sm">Your AI agent starts working immediately. Watch your productivity soar.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section id="services" class="py-20 sm:py-28 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-14">
        <p class="text-sm font-semibold text-[#ED2939] uppercase tracking-widest mb-3">Full-Service Development</p>
        <h2 class="text-3xl sm:text-4xl font-black text-gray-950 mb-4">Built for Every Stage of Growth</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="service-card">
          <h3 class="text-lg font-bold text-gray-900 mb-2">Enterprise Software</h3>
          <p class="text-gray-500 text-sm">Custom platforms tailored to your business.</p>
        </div>
        <div class="service-card">
          <h3 class="text-lg font-bold text-gray-900 mb-2">E-Commerce</h3>
          <p class="text-gray-500 text-sm">High-converting stores with seamless UX.</p>
        </div>
        <div class="service-card">
          <h3 class="text-lg font-bold text-gray-900 mb-2">API & EDI</h3>
          <p class="text-gray-500 text-sm">Robust integrations that keep data flowing.</p>
        </div>
        <div class="service-card">
          <h3 class="text-lg font-bold text-gray-900 mb-2">Mobile & Web</h3>
          <p class="text-gray-500 text-sm">Polished apps built for every platform.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- PORTFOLIO -->
  <section id="work" class="py-20 sm:py-28 bg-gray-50 dot-grid">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-14">
        <p class="text-sm font-semibold text-[#ED2939] uppercase tracking-widest mb-3">Portfolio</p>
        <h2 class="text-3xl sm:text-4xl font-black text-gray-950 mb-4">Our Notable Works</h2>
        <p class="text-base sm:text-lg text-gray-500 max-w-2xl mx-auto">We have partnered with organizations across retail, hospitality, faith, and tech to deliver lasting impact.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
        <a href="https://www.fairwaymarket.com" target="_blank" rel="noopener" class="client-card group">
          <div class="w-10 h-10 rounded-lg bg-[#002395] flex items-center justify-center mb-4">
            <svg width="20" height="20" fill="white" viewBox="0 0 24 24"><path d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
          </div>
          <h3 class="font-bold text-gray-900 mb-1 group-hover:text-[#002395] transition-colors">Fairway Market</h3>
          <p class="text-sm text-gray-500 leading-relaxed">E-commerce and digital infrastructure for a leading NYC grocer.</p>
          <span class="text-xs text-[#002395] font-semibold mt-3 inline-block">View Project &rarr;</span>
        </a>
        <a href="https://saintpatrickscathedral.org" target="_blank" rel="noopener" class="client-card group">
          <div class="w-10 h-10 rounded-lg bg-[#ED2939] flex items-center justify-center mb-4">
            <svg width="20" height="20" fill="white" viewBox="0 0 24 24"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
          </div>
          <h3 class="font-bold text-gray-900 mb-1 group-hover:text-[#ED2939] transition-colors">Saint Patrick's Cathedral</h3>
          <p class="text-sm text-gray-500 leading-relaxed">Web solutions for one of NYC's most iconic landmark institutions.</p>
