---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
---

<Layout>
  <!-- NAV -->
  <header class="fixed top-0 left-0 right-0 z-50 bg-[#001a6e] shadow-lg">
    <nav class="max-w-7xl mx-auto px-4 sm:px-6 py-3 flex items-center justify-between">
      <a href="/" class="flex items-center shrink-0">
        <img src="/logo-original.png" alt="GardeDev" class="h-8 sm:h-10 w-auto" />
      </a>
      <div class="hidden md:flex items-center gap-8">
        <a href="#services" class="nav-link-dark">Services</a>
        <a href="#work" class="nav-link-dark">Work</a>
        <a href="#about" class="nav-link-dark">About</a>
        <a href="#contact" class="btn-primary text-sm py-2 px-5">Let's Talk</a>
      </div>
      <button id="menu-btn" class="md:hidden p-2 rounded-lg hover:bg-blue-800 shrink-0" aria-label="Menu">
        <svg width="24" height="24" fill="none" stroke="white" stroke-width="2"><path d="M4 6h16M4 12h16M4 18h16"/></svg>
      </button>
    </nav>
    <div id="mobile-menu" class="hidden md:hidden bg-[#001a6e] border-t border-blue-800 px-4 py-4 flex flex-col gap-3">
      <a href="#services" class="nav-link-dark py-3 border-b border-blue-800 text-base font-medium">Services</a>
      <a href="#work" class="nav-link-dark py-3 border-b border-blue-800 text-base font-medium">Work</a>
      <a href="#about" class="nav-link-dark py-3 border-b border-blue-800 text-base font-medium">About</a>
      <a href="#contact" class="btn-primary text-center justify-center mt-2">Let's Talk</a>
    </div>
  </header>

  <!-- HERO -->
  <section class="relative min-h-screen flex items-center dot-grid pt-20 overflow-hidden">
    <div class="absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
      <svg class="absolute inset-0 w-full h-full" xmlns="http://www.w3.org/2000/svg">
        <line x1="75%" y1="15%" x2="85%" y2="40%" stroke="#002395" stroke-width="1" opacity="0.08"/>
        <line x1="85%" y1="40%" x2="70%" y2="60%" stroke="#002395" stroke-width="1" opacity="0.08"/>
        <line x1="60%" y1="25%" x2="75%" y2="15%" stroke="#002395" stroke-width="1" opacity="0.08"/>
        <circle cx="75%" cy="15%" r="5" fill="#002395" opacity="0.12"/>
        <circle cx="85%" cy="40%" r="7" fill="#002395" opacity="0.1"/>
        <circle cx="78%" cy="45%" r="80" fill="#002395" opacity="0.03"/>
      </svg>
      <div class="hero-art-el animate-float hidden md:block" style="right:8%;top:18%;opacity:0.07;">
        <svg width="120" height="120" viewBox="0 0 120 120"><polygon points="60,5 115,92 5,92" fill="none" stroke="#002395" stroke-width="2"/><polygon points="60,20 100,85 20,85" fill="#002395"/></svg>
      </div>
    </div>
    <div class="relative w-full max-w-7xl mx-auto px-4 sm:px-6 py-20 sm:py-28">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <div class="inline-flex items-center gap-2 bg-blue-50 text-[#002395] text-sm font-semibold px-4 py-2 rounded-full mb-6 border border-blue-100">
            <svg width="14" height="14" fill="#002395" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
            MBE Certified Company
          </div>
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-black leading-[1.1] mb-6 text-gray-950">
            Empowering your<br/>
            <span class="text-[#002395]">business</span> with<br/>
            <span class="relative inline-block text-[#002395]">cutting-edge AI.<span class="absolute -bottom-1 left-0 right-0 h-1.5 bg-[#ED2939] rounded"></span></span>
          </h1>
          <p class="text-lg sm:text-xl text-gray-500 mb-10 leading-relaxed">With deep expertise in modern technology and strong roots in multiple business domains, we deliver high-end web, mobile, and enterprise solutions from idea to launch and beyond.</p>
          <div class="flex flex-col sm:flex-row gap-4">
            <a href="#contact" class="btn-primary justify-center sm:justify-start">Let's Talk <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a>
            <a href="#work" class="btn-outline justify-center sm:justify-start">View Our Work</a>
          </div>
          <div class="mt-10 flex items-center gap-4">
            <div class="flex -space-x-2">
              <div class="w-9 h-9 rounded-full bg-[#002395] border-2 border-white flex items-center justify-center text-white text-xs font-bold">CR</div>
              <div class="w-9 h-9 rounded-full bg-[#ED2939] border-2 border-white flex items-center justify-center text-white text-xs font-bold">AM</div>
              <div class="w-9 h-9 rounded-full bg-gray-700 border-2 border-white flex items-center justify-center text-white text-xs font-bold">KP</div>
            </div>
            <p class="text-sm text-gray-500">Trusted by <span class="font-semibold text-gray-800">20+ clients</span> across industries</p>
          </div>
        </div>
        <div class="hidden lg:grid grid-cols-2 gap-4">
          <div class="bg-white rounded-2xl shadow-md p-6 border border-gray-100 flex flex-col gap-3">
            <div class="w-11 h-11 bg-blue-50 rounded-xl flex items-center justify-center"><svg width="22" height="22" fill="none" stroke="#002395" stroke-width="2" viewBox="0 0 24 24"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg></div>
            <h3 class="font-bold text-gray-900">Enterprise Software</h3><p class="text-sm text-gray-500">Custom platforms that scale with your business.</p>
          </div>
          <div class="bg-[#002395] rounded-2xl shadow-md p-6 flex flex-col gap-3 mt-8">
            <div class="w-11 h-11 bg-white/10 rounded-xl flex items-center justify-center"><svg width="22" height="22" fill="none" stroke="white" stroke-width="2" viewBox="0 0 24 24"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg></div>
            <h3 class="font-bold text-white">E-Commerce</h3><p class="text-sm text-blue-200">High-converting stores with seamless UX.</p>
          </div>
          <div class="bg-[#ED2939] rounded-2xl shadow-md p-6 flex flex-col gap-3">
            <div class="w-11 h-11 bg-white/10 rounded-xl flex items-center justify-center"><svg width="22" height="22" fill="none" stroke="white" stroke-width="2" viewBox="0 0 24 24"><path d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg></div>
            <h3 class="font-bold text-white">API & EDI</h3><p class="text-sm text-red-100">Robust integrations that keep data flowing.</p>
          </div>
          <div class="bg-white rounded-2xl shadow-md p-6 border border-gray-100 flex flex-col gap-3 mt-8">
            <div class="w-11 h-11 bg-red-50 rounded-xl flex items-center justify-center"><svg width="22" height="22" fill="none" stroke="#ED2939" stroke-width="2" viewBox="0 0 24 24"><rect x="5" y="2" width="14" height="20" rx="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg></div>
            <h3 class="font-bold text-gray-900">Mobile & Web</h3><p class="text-sm text-gray-500">Polished apps built for every platform.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- STATS -->
  <section class="py-14 bg-[#002395]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        <div class="text-center"><div class="text-4xl sm:text-5xl font-black text-white mb-1">10<span class="text-[#ED2939]">+</span></div><div class="text-blue-200 text-sm font-medium">Years of Experience</div></div>
        <div class="text-center"><div class="text-4xl sm:text-5xl font-black text-white mb-1"><span class="text-[#ED2939]">$</span>2M<span class="text-[#ED2939]">+</span></div><div class="text-blue-200 text-sm font-medium">Revenue Conversions</div></div>
        <div class="text-center"><div class="text-4xl sm:text-5xl font-black text-white mb-1">20<span class="text-[#ED2939]">+</span></div><div class="text-blue-200 text-sm font-medium">Technologies</div></div>
        <div class="text-center"><div class="text-4xl sm:text-5xl font-black text-white mb-1">98<span class="text-[#ED2939]">%</span></div><div class="text-blue-200 text-sm font-medium">Job Success Rate</div></div>
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section id="services" class="py-20 sm:py-28 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-14">
        <p class="text-sm font-semibold text-[#ED2939] uppercase tracking-widest mb-3">What We Do</p>
        <h2 class="text-3xl sm:text-4xl font-black text-gray-950 mb-4">Built for every stage of growth</h2>
        <p class="text-base sm:text-lg text-gray-500 max-w-2xl mx-auto">From initial concept to full-scale enterprise systems, we have the expertise to deliver end-to-end.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="service-card">
          <div class="w-12 h-12 bg-blue-50 rounded-xl flex items-center justify-center mb-5"><svg width="24" height="24" fill="none" stroke="#002395" stroke-width="2" viewBox="0 0 24 24"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg></div>
          <h3 class="text-lg font-bold text-gray-900 mb-2">Enterprise Software</h3>
          <p class="text-gray-500 text-sm leading-relaxed">Custom-built platforms tailored to your business. Scalable, maintainable, and designed to grow with you.</p>
          <ul class="mt-4 space-y-1.5">
            <li class="text-xs text-gray-400 flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-[#002395] shrink-0 inline-block"></span>CRM &amp; ERP Systems</li>
            <li class="text-xs text-gray-400 flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-[#002395] shrink-0 inline-block"></span>Workflow Automation</li>
            <li class="text-xs text-gray-400 flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-[#002395] shrink-0 inline-block"></span>Cloud Infrastructure</li>
          </ul>
        </div>
        <div class="service-card" style="border-top-color:#ED2939;">
          <div class="w-12 h-12 bg-red-50 rounded-xl flex items-center justify-center mb-5"><svg width="24" height="24" fill="none" stroke="#ED2939" stroke-width="2" viewBox="0 0 24 24"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg></div>
          <h3 class="text-lg font-bold text-gray-900 mb-2">E-Commerce Websites</h3>
          <p class="text-gray-500 text-sm leading-relaxed">High-converting stores with seamless UX, inventory management, and payment integrations that drive revenue.</p>
          <ul class="mt-4 space-y-1.5">
            <li class="text-xs text-gray-400 flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-[#ED2939] shrink-0 inline-block"></span>Custom Storefronts</li>
            <li class="text-xs text-gray-400 flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-[#ED2939] shrink-0 inline-block"></span>Payment Gateways</li>
            <li class="text-xs text-gray-400 flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-[#ED2939] shrink-0 inline-block"></span>Inventory &amp; Fulfillment</li>
          </ul>
        </div>
        <div class="service-card">
          <div class="w-12 h-12 bg-blue-50 rounded-xl flex items-center justify-center mb-5"><svg width="24" height="24" fill="none" stroke="#002395" stroke-width="2" viewBox="0 0 24 24"><path d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg></div>
          <h3 class="text-lg font-bold text-gray-900 mb-2">API &amp; EDI Integrations</h3>
          <p class="text-gray-500 text-sm leading-relaxed">Connect your systems seamlessly. Robust integrations that keep your data flowing reliably at scale.</p>
          <ul class="mt-4 space-y-1.5">
            <li class="text-xs text-gray-400 flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-[#002395] shrink-0 inline-block"></span>REST &amp; GraphQL APIs</li>
            <li class="text-xs text-gray-400 flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-[#002395] shrink-0 inline-block"></span>EDI 850 / 856 / 810</li>
            <li class="text-xs text-gray-400 flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-[#002395] shrink-0 inline-block"></span>Third-Party Connectors</li>
          </ul>
        </div>
        <div class="service-card" style="border-top-color:#ED2939;">
          <div class="w-12 h-12 bg-red-50 rounded-xl flex items-center justify-center mb-5"><svg width="24" height="24" fill="none" stroke="#ED2939" stroke-width="2" viewBox="0 0 24 24"><rect x="5" y="2" width="14" height="20" rx="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg></div>
          <h3 class="text-lg font-bold text-gray-900 mb-2">Mobile &amp; Web Apps</h3>
          <p class="text-gray-500 text-sm leading-relaxed">Polished, performant apps for web and mobile. Modern frameworks, optimized for real-world usage.</p>
          <ul class="mt-4 space-y-1.5">
            <li class="text-xs text-gray-400 flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-[#ED2939] shrink-0 inline-block"></span>React &amp; Next.js</li>
            <li class="text-xs text-gray-400 flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-[#ED2939] shrink-0 inline-block"></span>iOS &amp; Android Apps</li>
            <li class="text-xs text-gray-400 flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-[#ED2939] shrink-0 inline-block"></span>Progressive Web Apps</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- WHY GARDEDEV -->
  <section class="py-20 sm:py-28 bg-gray-50 dot-grid">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
        <div>
          <p class="text-sm font-semibold text-[#ED2939] uppercase tracking-widest mb-3">Why GardeDev</p>
          <h2 class="text-3xl sm:text-4xl font-black text-gray-950 mb-6">What makes us different?</h2>
          <p class="text-gray-600 leading-relaxed mb-4">GardeDev has an extensive history of developing custom software products tailored to the specific business needs of our clients, supporting them throughout the whole way from idea to implementation.</p>
          <p class="text-gray-600 leading-relaxed mb-8">With a deep understanding of modern technology and strong expertise in multiple business domains, our solid background, flexibility, and full transparency have enabled us to become a trusted technology partner across industries.</p>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            <div class="flex items-start gap-3 bg-white rounded-xl p-4 border border-gray-100 shadow-sm">
              <div class="w-8 h-8 bg-blue-50 rounded-lg flex items-center justify-center shrink-0"><svg width="14" height="14" fill="#002395" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg></div>
              <div><h4 class="font-semibold text-gray-900 text-sm">MBE Certified</h4><p class="text-xs text-gray-500 mt-0.5">Certified Minority Business Enterprise</p></div>
            </div>
            <div class="flex items-start gap-3 bg-white rounded-xl p-4 border border-gray-100 shadow-sm">
              <div class="w-8 h-8 bg-red-50 rounded-lg flex items-center justify-center shrink-0"><svg width="14" height="14" fill="#ED2939" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg></div>
              <div><h4 class="font-semibold text-gray-900 text-sm">Full Transparency</h4><p class="text-xs text-gray-500 mt-0.5">You always know what we're building</p></div>
            </div>
            <div class="flex items-start gap-3 bg-white rounded-xl p-4 border border-gray-100 shadow-sm">
              <div class="w-8 h-8 bg-blue-50 rounded-lg flex items-center justify-center shrink-0"><svg width="14" height="14" fill="#002395" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg></div>
              <div><h4 class="font-semibold text-gray-900 text-sm">End-to-End Delivery</h4><p class="text-xs text-gray-500 mt-0.5">From idea to launch and beyond</p></div>
            </div>
            <div class="flex items-start gap-3 bg-white rounded-xl p-4 border border-gray-100 shadow-sm">
              <div class="w-8 h-8 bg-red-50 rounded-lg flex items-center justify-center shrink-0"><svg width="14" height="14" fill="#ED2939" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg></div>
              <div><h4 class="font-semibold text-gray-900 text-sm">Multi-Domain Expertise</h4><p class="text-xs text-gray-500 mt-0.5">Retail, hospitality, finance &amp; more</p></div>
            </div>
          </div>
        </div>
        <div>
          <p class="text-sm font-semibold text-gray-400 uppercase tracking-widest mb-5 text-center lg:text-left">Technologies We Work With</p>
          <div class="grid grid-cols-3 gap-3">
            <div class="bg-white border border-gray-100 rounded-xl p-4 text-center shadow-sm"><div class="font-black text-[#002395] text-base">React</div><div class="text-xs text-gray-400 mt-1">Frontend</div></div>
            <div class="bg-white border border-gray-100 rounded-xl p-4 text-center shadow-sm"><div class="font-black text-[#ED2939] text-base">Node.js</div><div class="text-xs text-gray-400 mt-1">Backend</div></div>
            <div class="bg-white border border-gray-100 rounded-xl p-4 text-center shadow-sm"><div class="font-black text-[#002395] text-base">AWS</div><div class="text-xs text-gray-400 mt-1">Cloud</div></div>
            <div class="bg-white border border-gray-100 rounded-xl p-4 text-center shadow-sm"><div class="font-black text-[#ED2939] text-base">Python</div><div class="text-xs text-gray-400 mt-1">AI &amp; Data</div></div>
            <div class="bg-white border border-gray-100 rounded-xl p-4 text-center shadow-sm"><div class="font-black text-[#002395] text-base">Next.js</div><div class="text-xs text-gray-400 mt-1">Full-Stack</div></div>
            <div class="bg-white border border-gray-100 rounded-xl p-4 text-center shadow-sm"><div class="font-black text-[#ED2939] text-base">MySQL</div><div class="text-xs text-gray-400 mt-1">Database</div></div>
            <div class="bg-white border border-gray-100 rounded-xl p-4 text-center shadow-sm"><div class="font-black text-[#002395] text-base">PHP</div><div class="text-xs text-gray-400 mt-1">Backend</div></div>
            <div class="bg-white border border-gray-100 rounded-xl p-4 text-center shadow-sm"><div class="font-black text-[#ED2939] text-base">iOS</div><div class="text-xs text-gray-400 mt-1">Mobile</div></div>
            <div class="bg-white border border-gray-100 rounded-xl p-4 text-center shadow-sm"><div class="font-black text-[#002395] text-base">EDI</div><div class="text-xs text-gray-400 mt-1">Integrations</div></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- NOTABLE WORK -->
  <section id="work" class="py-20 sm:py-28 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-14">
        <p class="text-sm font-semibold text-[#ED2939] uppercase tracking-widest mb-3">Portfolio</p>
        <h2 class="text-3xl sm:text-4xl font-black text-gray-950 mb-4">Our Notable Works</h2>
        <p class="text-base sm:text-lg text-gray-500 max-w-2xl mx-auto">We have partnered with organizations across retail, hospitality, faith, and tech to deliver lasting impact.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
        <a href="https://www.fairwaymarket.com" target="_blank" rel="noopener" class="client-card group">
          <div class="w-10 h-10 rounded-lg bg-[#002395] flex items-center justify-center mb-4">
            <svg width="20" height="20" fill="white" viewBox="0 0 24 24"><path d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
          </div>
          <h3 class="font-bold text-gray-900 mb-1 group-hover:text-[#002395] transition-colors">Fairway Market</h3>
          <p class="text-sm text-gray-500 leading-relaxed">E-commerce and digital infrastructure for a leading NYC grocer, serving thousands of daily customers.</p>
          <span class="text-xs text-[#002395] font-semibold mt-3 inline-block">View Project &rarr;</span>
        </a>
        <a href="https://saintpatrickscathedral.org" target="_blank" rel="noopener" class="client-card group">
          <div class="w-10 h-10 rounded-lg bg-[#ED2939] flex items-center justify-center mb-4">
            <svg width="20" height="20" fill="white" viewBox="0 0 24 24"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
          </div>
          <h3 class="font-bold text-gray-900 mb-1 group-hover:text-[#ED2939] transition-colors">Saint Patrick's Cathedral</h3>
          <p class="text-sm text-gray-500 leading-relaxed">Web solutions for one of NYC's most iconic and visited landmark institutions.</p>
          <span class="text-xs text-[#ED2939] font-semibold mt-3 inline-block">View Project &rarr;</span>
        </a>
        <a href="https://www.logoup.com" target="_blank" rel="noopener" class="client-card group">
          <div class="w-10 h-10 rounded-lg bg-[#002395] flex items-center justify-center mb-4">
