  <script>
    const btn = document.getElementById('menu-btn');
    const menu = document.getElementById('mobile-menu');
    btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));

    const contactForm = document.getElementById('contactForm');
    contactForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const token = (window as any).hcaptcha?.getResponse();
      if (!token) { alert('Please complete the CAPTCHA to continue.'); return; }
      const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement;
      submitBtn.textContent = 'Sending…'; submitBtn.disabled = true;
      try {
        const formData = new FormData(contactForm as HTMLFormElement);
        formData.delete('h-captcha-response'); formData.append('h-captcha-response', token);
        const res = await fetch('https://formspree.io/f/xbdzgegq', { method: 'POST', body: formData, headers: { 'Accept': 'application/json' } });
        const json = await res.json();
        if (res.ok) { window.location.href = '/thank-you'; }
        else { submitBtn.textContent = 'Send Message'; submitBtn.disabled = false; (window as any).hcaptcha?.reset(); alert((json.errors && json.errors.map((err: any) => err.message).join(', ')) || 'Something went wrong.'); }
      } catch { submitBtn.textContent = 'Send Message'; submitBtn.disabled = false; (window as any).hcaptcha?.reset(); alert('Network error. Please try again.'); }
    });
  </script>
