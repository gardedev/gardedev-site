---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
---

<Layout>
  <!-- NAV -->
  <header class="fixed top-0 left-0 right-0 z-50 bg-white/95 backdrop-blur-sm border-b-2 border-[#002395]">
    <nav class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
      <a href="/" class="flex items-center">
        <img src="/logo-color.png" alt="GardeDev" class="h-8 w-auto" />
      </a>
      <div class="hidden md:flex items-center gap-8">
        <a href="#services" class="nav-link">Services</a>
        <a href="#work" class="nav-link">Work</a>
        <a href="#team" class="nav-link">Team</a>
        <a href="#about" class="nav-link">About</a>
        <a href="#contact" class="btn-primary text-sm py-2 px-5">Let's Talk</a>
      </div>
      <!-- Mobile menu button -->
      <button id="menu-btn" class="md:hidden p-2 rounded-lg hover:bg-gray-100" aria-label="Menu">
        <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </nav>
    <!-- Mobile menu -->
    <div id="mobile-menu" class="hidden md:hidden bg-white border-t border-gray-100 px-6 py-4 flex flex-col gap-4">
      <a href="#services" class="nav-link">Services</a>
      <a href="#work" class="nav-link">Work</a>
      <a href="#team" class="nav-link">Team</a>
      <a href="#about" class="nav-link">About</a>
      <a href="#contact" class="btn-primary text-center">Let's Talk</a>
    </div>
  </header>

  <!-- HERO -->
  <section class="relative min-h-screen flex items-center dot-grid pt-20 overflow-hidden">
    <!-- Abstract hero art SVG -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
      <!-- Network nodes -->
      <svg class="absolute inset-0 w-full h-full" xmlns="http://www.w3.org/2000/svg">
        <!-- Connection lines -->
        <line x1="75%" y1="15%" x2="85%" y2="40%" stroke="#002395" stroke-width="1" opacity="0.08"/>
        <line x1="85%" y1="40%" x2="70%" y2="60%" stroke="#002395" stroke-width="1" opacity="0.08"/>
        <line x1="70%" y1="60%" x2="80%" y2="80%" stroke="#ED2939" stroke-width="1" opacity="0.07"/>
        <line x1="60%" y1="25%" x2="75%" y2="15%" stroke="#002395" stroke-width="1" opacity="0.08"/>
        <line x1="60%" y1="25%" x2="70%" y2="60%" stroke="#002395" stroke-width="1.5" opacity="0.06"/>
        <line x1="90%" y1="20%" x2="85%" y2="40%" stroke="#ED2939" stroke-width="1" opacity="0.07"/>
        <line x1="55%" y1="70%" x2="70%" y2="60%" stroke="#002395" stroke-width="1" opacity="0.08"/>
        <line x1="55%" y1="70%" x2="65%" y2="85%" stroke="#ED2939" stroke-width="1" opacity="0.06"/>
        <!-- Network nodes (circles) -->
        <circle cx="75%" cy="15%" r="5" fill="#002395" opacity="0.12"/>
        <circle cx="85%" cy="40%" r="7" fill="#002395" opacity="0.1"/>
        <circle cx="70%" cy="60%" r="5" fill="#002395" opacity="0.1"/>
        <circle cx="80%" cy="80%" r="4" fill="#ED2939" opacity="0.1"/>
        <circle cx="60%" cy="25%" r="6" fill="#ED2939" opacity="0.1"/>
        <circle cx="90%" cy="20%" r="4" fill="#002395" opacity="0.09"/>
        <circle cx="55%" cy="70%" r="6" fill="#002395" opacity="0.1"/>
        <circle cx="65%" cy="85%" r="3" fill="#ED2939" opacity="0.08"/>
        <!-- Larger ambient circles -->
        <circle cx="78%" cy="45%" r="80" fill="#002395" opacity="0.03"/>
        <circle cx="62%" cy="65%" r="60" fill="#ED2939" opacity="0.03"/>
      </svg>

      <!-- Floating geometric shapes -->
      <div class="hero-art-el animate-float" style="right: 8%; top: 18%; opacity: 0.07;">
        <svg width="120" height="120" viewBox="0 0 120 120">
          <polygon points="60,5 115,92 5,92" fill="none" stroke="#002395" stroke-width="2"/>
          <polygon points="60,20 100,85 20,85" fill="#002395"/>
        </svg>
      </div>

      <div class="hero-art-el animate-float-reverse" style="right: 22%; top: 55%; opacity: 0.06;">
        <svg width="90" height="90" viewBox="0 0 90 90">
          <rect x="5" y="5" width="80" height="80" fill="none" stroke="#ED2939" stroke-width="1.5" transform="rotate(15 45 45)"/>
          <rect x="15" y="15" width="60" height="60" fill="#ED2939" opacity="0.4" transform="rotate(15 45 45)"/>
        </svg>
      </div>

      <div class="hero-art-el animate-float-slow" style="right: 5%; top: 65%; opacity: 0.07;">
        <svg width="70" height="80" viewBox="0 0 70 80">
          <polygon points="35,0 70,20 70,60 35,80 0,60 0,20" fill="none" stroke="#002395" stroke-width="1.5"/>
          <polygon points="35,10 60,23 60,57 35,70 10,57 10,23" fill="#002395" opacity="0.3"/>
        </svg>
      </div>

      <!-- Code bracket art -->
      <div class="hero-art-el animate-pulse-slow" style="right: 35%; top: 12%; opacity: 0.08;">
        <svg width="100" height="60" viewBox="0 0 100 60" font-family="monospace">
          <text x="0" y="18" font-size="14" fill="#002395">{"{"}</text>
          <text x="12" y="34" font-size="11" fill="#002395">api: true,</text>
          <text x="12" y="48" font-size="11" fill="#ED2939">deploy: now</text>
          <text x="0" y="58" font-size="14" fill="#002395">{"}"}</text>
        </svg>
      </div>

      <!-- Circuit trace lines -->
      <div class="hero-art-el" style="right: 15%; bottom: 15%; opacity: 0.06;">
        <svg width="200" height="120" viewBox="0 0 200 120">
          <path d="M10 60 H60 V20 H120 V60 H180" fill="none" stroke="#002395" stroke-width="2"/>
          <path d="M60 60 V100 H140" fill="none" stroke="#ED2939" stroke-width="1.5"/>
          <circle cx="60" cy="60" r="4" fill="#002395"/>
          <circle cx="120" cy="20" r="4" fill="#ED2939"/>
          <circle cx="120" cy="60" r="3" fill="#002395"/>
          <circle cx="140" cy="100" r="3" fill="#ED2939"/>
        </svg>
      </div>

      <!-- Binary stream -->
      <div class="hero-art-el animate-float" style="right: 42%; top: 70%; opacity: 0.05; font-family: monospace; font-size: 11px; color: #002395; letter-spacing: 2px; line-height: 1.6;">
        10110010<br/>01001101<br/>11010011<br/>00101110
      </div>

      <!-- Data bars -->
      <div class="hero-art-el animate-float-reverse" style="right: 28%; bottom: 20%; opacity: 0.07;">
        <svg width="80" height="60" viewBox="0 0 80 60">
          <rect x="0" y="30" width="12" height="30" fill="#002395"/>
          <rect x="16" y="15" width="12" height="45" fill="#002395"/>
          <rect x="32" y="22" width="12" height="38" fill="#ED2939"/>
          <rect x="48" y="5" width="12" height="55" fill="#002395"/>
          <rect x="64" y="18" width="12" height="42" fill="#ED2939"/>
        </svg>
      </div>
    </div>

    <!-- Hero content -->
    <div class="relative max-w-6xl mx-auto px-6 py-24">
      <div class="max-w-2xl">
        <div class="inline-flex items-center gap-2 bg-blue-50 text-[#002395] text-sm font-semibold px-4 py-2 rounded-full mb-6 border border-blue-100">
          <svg width="16" height="16" fill="#002395" viewBox="0 0 20 20"><path d="M10 0C4.477 0 0 4.477 0 10s4.477 10 10 10 10-4.477 10-10S15.523 0 10 0zm0 18a8 8 0 110-16 8 8 0 010 16zm1-11H9v4H5l5 5 5-5h-4V7z"/></svg>
          MBE Certified Company
        </div>
        <h1 class="text-5xl md:text-6xl lg:text-7xl font-black leading-tight mb-2 text-gray-950">
          We build things
        </h1>
        <h1 class="text-5xl md:text-6xl lg:text-7xl font-black leading-tight mb-6 text-[#002395]">
          that <span class="relative inline-block">work.
            <span class="absolute bottom-1 left-0 right-0 h-1 bg-[#ED2939] rounded"></span>
          </span>
        </h1>
        <p class="text-xl text-gray-500 mb-10 leading-relaxed max-w-lg">
          Custom software, web & mobile solutions for ambitious businesses. From enterprise platforms to e-commerce, we deliver end-to-end.
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="#contact" class="btn-primary">
            Let's Talk
            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <a href="#work" class="btn-outline">View Our Work</a>
        </div>
        <div class="mt-12 flex items-center gap-6">
          <div class="flex -space-x-2">
            <!-- Geometric avatar stack -->
            <div class="w-9 h-9 rounded-full bg-[#002395] border-2 border-white flex items-center justify-center text-white text-xs font-bold">JR</div>
            <div class="w-9 h-9 rounded-full bg-[#ED2939] border-2 border-white flex items-center justify-center text-white text-xs font-bold">AM</div>
            <div class="w-9 h-9 rounded-full bg-gray-700 border-2 border-white flex items-center justify-center text-white text-xs font-bold">KP</div>
          </div>
          <p class="text-sm text-gray-500">Trusted by <span class="font-semibold text-gray-800">20+ clients</span> across industries</p>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section id="services" class="py-24 bg-white">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-16">
        <p class="text-sm font-semibold text-[#ED2939] uppercase tracking-widest mb-3">What We Do</p>
        <h2 class="text-4xl font-black text-gray-950 mb-4">Built for every stage of growth</h2>
        <p class="text-lg text-gray-500 max-w-xl mx-auto">From initial concept to full-scale enterprise systems, we have the expertise to deliver.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <!-- Enterprise Software -->
        <div class="service-card">
          <div class="w-12 h-12 bg-blue-50 rounded-xl flex items-center justify-center mb-5">
            <svg width="24" height="24" fill="none" stroke="#002395" stroke-width="2" viewBox="0 0 24 24">
              <rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-2">Enterprise Software</h3>
          <p class="text-gray-500 leading-relaxed">Custom-built platforms tailored to your business processes. Scalable, maintainable, and designed to grow with you.</p>
        </div>
        <!-- E-Commerce -->
        <div class="service-card">
          <div class="w-12 h-12 bg-red-50 rounded-xl flex items-center justify-center mb-5">
            <svg width="24" height="24" fill="none" stroke="#ED2939" stroke-width="2" viewBox="0 0 24 24">
              <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-2">E-Commerce Websites</h3>
          <p class="text-gray-500 leading-relaxed">High-converting online stores with seamless UX, inventory management, and payment integrations that drive revenue.</p>
        </div>
        <!-- API/EDI -->
        <div class="service-card">
          <div class="w-12 h-12 bg-blue-50 rounded-xl flex items-center justify-center mb-5">
            <svg width="24" height="24" fill="none" stroke="#002395" stroke-width="2" viewBox="0 0 24 24">
              <path d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-2">API & EDI Integrations</h3>
          <p class="text-gray-500 leading-relaxed">Connect your systems seamlessly. We architect and implement robust integrations that keep your data flowing reliably.</p>
        </div>
        <!-- Mobile & Web -->
        <div class="service-card">
          <div class="w-12 h-12 bg-red-50 rounded-xl flex items-center justify-center mb-5">
            <svg width="24" height="24" fill="none" stroke="#ED2939" stroke-width="2" viewBox="0 0 24 24">
              <rect x="5" y="2" width="14" height="20" rx="2"/><line x1="12" y1="18" x2="12.01" y2="18"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-2">Mobile & Web Apps</h3>
          <p class="text-gray-500 leading-relaxed">Polished, performant applications for web and mobile. Built with modern frameworks, optimized for real-world usage.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- STATS -->
  <section class="py-20 bg-[#002395]">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
        <div class="stat-card text-center">
          <div class="text-5xl font-black text-white mb-2">10<span class="text-[#ED2939]">+</span></div>
          <div class="text-blue-200 font-medium">Years of Experience</div>
        </div>
        <div class="stat-card text-center">
          <div class="text-5xl font-black text-white mb-2"><span class="text-[#ED2939]">$</span>2M<span class="text-[#ED2939]">+</span></div>
          <div class="text-blue-200 font-medium">Revenue Generated</div>
        </div>
        <div class="stat-card text-center">
          <div class="text-5xl font-black text-white mb-2">20<span class="text-[#ED2939]">+</span></div>
          <div class="text-blue-200 font-medium">Technologies</div>
        </div>
        <div class="stat-card text-center">
          <div class="text-5xl font-black text-white mb-2">98<span class="text-[#ED2939]">%</span></div>
          <div class="text-blue-200 font-medium">Job Success Rate</div>
        </div>
      </div>
    </div>
  </section>

  <!-- NOTABLE WORK -->
  <section id="work" class="py-24 bg-gray-50 dot-grid">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-16">
        <p class="text-sm font-semibold text-[#ED2939] uppercase tracking-widest mb-3">Portfolio</p>
        <h2 class="text-4xl font-black text-gray-950 mb-4">Notable Clients</h2>
        <p class="text-lg text-gray-500 max-w-xl mx-auto">We've partnered with organizations across retail, hospitality, faith, and tech to deliver lasting impact.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
        <a href="https://www.fairwaymarket.com" target="_blank" rel="noopener" class="client-card group">
          <div class="w-10 h-10 rounded-lg bg-[#002395] flex items-center justify-center mb-4">
            <svg width="20" height="20" fill="white" viewBox="0 0 24 24"><path d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
          </div>
          <h3 class="font-bold text-gray-900 mb-1 group-hover:text-[#002395] transition-colors">Fairway Market</h3>
          <p class="text-sm text-gray-500">E-commerce & digital infrastructure for a leading NYC grocer.</p>
          <span class="text-xs text-[#002395] font-semibold mt-3 inline-block">View Project →</span>
        </a>
        <a href="https://saintpatrickscathedral.org" target="_blank" rel="noopener" class="client-card group">
          <div class="w-10 h-10 rounded-lg bg-[#ED2939] flex items-center justify-center mb-4">
            <svg width="20" height="20" fill="white" viewBox="0 0 24 24"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
          </div>
          <h3 class="font-bold text-gray-900 mb-1 group-hover:text-[#ED2939] transition-colors">Saint Patrick's Cathedral</h3>
          <p class="text-sm text-gray-500">Web solutions for one of NYC's most iconic landmark institutions.</p>
          <span class="text-xs text-[#ED2939] font-semibold mt-3 inline-block">View Project →</span>
        </a>
        <a href="https://www.logoup.com" target="_blank" rel="noopener" class="client-card group">
          <div class="w-10 h-10 rounded-lg bg-[#002395] flex items-center justify-center mb-4">
            <svg width="20" height="20" fill="white" viewBox="0 0 24 24"><path d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zM16 13a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z"/></svg>
          </div>
          <h3 class="font-bold text-gray-900 mb-1 group-hover:text-[#002395] transition-colors">LogoUp</h3>
          <p class="text-sm text-gray-500">Custom platform development for a branded merchandise marketplace.</p>
          <span class="text-xs text-[#002395] font-semibold mt-3 inline-block">View Project →</span>
        </a>
        <a href="https://www.alldayshirts.com" target="_blank" rel="noopener" class="client-card group">
          <div class="w-10 h-10 rounded-lg bg-[#ED2939] flex items-center justify-center mb-4">
            <svg width="20" height="20" fill="white" viewBox="0 0 24 24"><path d="M20.38 3.46L16 2a4 4 0 01-8 0L3.62 3.46a2 2 0 00-1.34 2.23l.58 3.57a1 1 0 00.99.84H6v10c0 1.1.9 2 2 2h8a2 2 0 002-2V10h2.15a1 1 0 00.99-.84l.58-3.57a2 2 0 00-1.34-2.23z"/></svg>
          </div>
          <h3 class="font-bold text-gray-900 mb-1 group-hover:text-[#ED2939] transition-colors">AllDayShirts</h3>
          <p class="text-sm text-gray-500">Full-stack e-commerce and operations platform for custom apparel.</p>
          <span class="text-xs text-[#ED2939] font-semibold mt-3 inline-block">View Project →</span>
        </a>
      </div>
    </div>
  </section>

  <!-- TEAM -->
  <section id="team" class="py-24 bg-white">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-16">
        <p class="text-sm font-semibold text-[#ED2939] uppercase tracking-widest mb-3">The Team</p>
        <h2 class="text-4xl font-black text-gray-950 mb-4">People who ship</h2>
        <p class="text-lg text-gray-500 max-w-xl mx-auto">A focused team of engineers, designers, and strategists who care about the details.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Team member 1 -->
        <div class="text-center">
          <div class="w-24 h-24 rounded-2xl mx-auto mb-5 bg-gradient-to-br from-[#002395] to-blue-400 flex items-center justify-center shadow-lg">
            <svg width="48" height="48" viewBox="0 0 48 48" fill="none">
              <circle cx="24" cy="18" r="10" fill="white" opacity="0.9"/>
              <path d="M4 44c0-11 8.954-20 20-20s20 8.954 20 20" stroke="white" stroke-width="3" stroke-linecap="round" opacity="0.7"/>
            </svg>
          </div>
          <h3 class="text-lg font-bold text-gray-900 mb-1">Lead Engineer</h3>
          <p class="text-sm text-[#002395] font-semibold mb-3">Architecture & Backend</p>
          <p class="text-sm text-gray-500 max-w-xs mx-auto">10+ years building scalable systems. Expert in cloud infrastructure, APIs, and enterprise software design.</p>
          <div class="flex justify-center gap-2 mt-4">
            <span class="text-xs bg-blue-50 text-[#002395] px-3 py-1 rounded-full font-medium">Node.js</span>
            <span class="text-xs bg-blue-50 text-[#002395] px-3 py-1 rounded-full font-medium">AWS</span>
            <span class="text-xs bg-blue-50 text-[#002395] px-3 py-1 rounded-full font-medium">Python</span>
          </div>
        </div>
        <!-- Team member 2 -->
        <div class="text-center">
          <div class="w-24 h-24 rounded-2xl mx-auto mb-5 bg-gradient-to-br from-[#ED2939] to-orange-400 flex items-center justify-center shadow-lg">
            <svg width="48" height="48" viewBox="0 0 48 48" fill="none">
              <circle cx="24" cy="18" r="10" fill="white" opacity="0.9"/>
              <path d="M4 44c0-11 8.954-20 20-20s20 8.954 20 20" stroke="white" stroke-width="3" stroke-linecap="round" opacity="0.7"/>
            </svg>
          </div>
          <h3 class="text-lg font-bold text-gray-900 mb-1">UX Architect</h3>
          <p class="text-sm text-[#ED2939] font-semibold mb-3">Design & Frontend</p>
          <p class="text-sm text-gray-500 max-w-xs mx-auto">Designs interfaces that feel effortless. Specializes in design systems, accessibility, and conversion-focused UX.</p>
          <div class="flex justify-center gap-2 mt-4">
            <span class="text-xs bg-red-50 text-[#ED2939] px-3 py-1 rounded-full font-medium">React</span>
            <span class="text-xs bg-red-50 text-[#ED2939] px-3 py-1 rounded-full font-medium">Figma</span>
            <span class="text-xs bg-red-50 text-[#ED2939] px-3 py-1 rounded-full font-medium">CSS</span>
          </div>
        </div>
        <!-- Team member 3 -->
        <div class="text-center">
          <div class="w-24 h-24 rounded-2xl mx-auto mb-5 bg-gradient-to-br from-gray-700 to-gray-500 flex items-center justify-center shadow-lg">
            <svg width="48" height="48" viewBox="0 0 48 48" fill="none">
              <circle cx="24" cy="18" r="10" fill="white" opacity="0.9"/>
              <path d="M4 44c0-11 8.954-20 20-20s20 8.954 20 20" stroke="white" stroke-width="3" stroke-linecap="round" opacity="0.7"/>
            </svg>
          </div>
          <h3 class="text-lg font-bold text-gray-900 mb-1">Solutions Consultant</h3>
          <p class="text-sm text-gray-600 font-semibold mb-3">Strategy & Integrations</p>
          <p class="text-sm text-gray-500 max-w-xs mx-auto">Bridges business and technology. Leads discovery, architecture planning, and complex API & EDI projects.</p>
          <div class="flex justify-center gap-2 mt-4">
            <span class="text-xs bg-gray-100 text-gray-700 px-3 py-1 rounded-full font-medium">EDI</span>
            <span class="text-xs bg-gray-100 text-gray-700 px-3 py-1 rounded-full font-medium">APIs</span>
            <span class="text-xs bg-gray-100 text-gray-700 px-3 py-1 rounded-full font-medium">Strategy</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ABOUT -->
  <section id="about" class="py-24 bg-gray-950 dot-grid">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-center">
        <div>
          <p class="text-sm font-semibold text-[#ED2939] uppercase tracking-widest mb-3">About GardeDev</p>
          <h2 class="text-4xl font-black text-white mb-6">We don&#39;t just write code.<br/>We solve problems.</h2>
          <p class="text-gray-400 leading-relaxed mb-5">
