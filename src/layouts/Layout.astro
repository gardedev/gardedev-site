---
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
}
const {
  title = "GardeDev – Custom Software & Web Solutions | MBE Certified",
  description = "GardeDev builds enterprise software, e-commerce solutions, API integrations, and mobile & web applications. MBE Certified. Trusted by leading organizations."
} = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/png" href="/logo.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  </head>
  <body>
    <slot />
  </body>
</html>
